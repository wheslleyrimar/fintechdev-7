{
  "title": "Security Dashboard",
  "uid": "security-aula7",
  "schemaVersion": 38,
  "refresh": "10s",
  "panels": [
    {
      "id": 1,
      "title": "Auth Attempts (success vs failure)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "rate(auth_attempts_total{status=\"success\"}[1m])",
          "legendFormat": "success - {{type}}",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        },
        {
          "expr": "rate(auth_attempts_total{status=\"failure\"}[1m])",
          "legendFormat": "failure - {{type}}",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        }
      ],
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    },
    {
      "id": 2,
      "title": "Auth Failures by Reason",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "rate(auth_failures_total[1m])",
          "legendFormat": "{{reason}}",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        }
      ],
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    },
    {
      "id": 3,
      "title": "Payment Auth Failures",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "rate(payment_auth_failures_total[1m])",
          "legendFormat": "{{reason}}",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        }
      ],
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    },
    {
      "id": 4,
      "title": "Payments Processed",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "rate(payments_processed_total[1m])",
          "legendFormat": "{{status}} - {{currency}}",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        }
      ],
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    },
    {
      "id": 5,
      "title": "Token Validations",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 16, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "rate(token_validations_total[1m])",
          "legendFormat": "{{status}}",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        }
      ],
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    },
    {
      "id": 6,
      "title": "Secret Accesses",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 16, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "rate(secret_access_total[1m])",
          "legendFormat": "{{key}} - {{action}} - {{status}}",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        }
      ],
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    }
  ]
}
